<Window x:Class="PasteByDan.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paste by Dan" Width="360" Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="PromptLabel" Text="Enter value:" Foreground="#BBBBBB" FontFamily="Segoe UI" FontSize="13"/>
        <TextBox Grid.Row="2" x:Name="InputBox" Background="#2A2A2A" Foreground="White"
                 BorderBrush="#444" BorderThickness="1" Padding="8,6"
                 FontFamily="Segoe UI" FontSize="13" CaretBrush="White"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="70" Height="30" Margin="0,0,8,0"
                    Background="#333" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="OK" Width="70" Height="30"
                    Background="#5B8AF5" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="OK_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
