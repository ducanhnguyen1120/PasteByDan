<Window x:Class="PasteByDan.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Paste by Dan" Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#1A1A1A" Foreground="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontFamily="Segoe UI" FontSize="18"
                   FontWeight="SemiBold" Foreground="White"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Global Hotkey" Foreground="#888" FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,6"/>
            <Border Background="#2A2A2A" CornerRadius="6" Padding="12,8">
                <TextBlock x:Name="HotkeyLabel" Text="Ctrl + Shift + V"
                           Foreground="White" FontFamily="Segoe UI" FontSize="14"/>
            </Border>
            <TextBlock Text="(Hotkey is fixed as Ctrl+Shift+V in this version)"
                       Foreground="#555" FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="Dark Theme" Foreground="#BBBBBB" FontFamily="Segoe UI" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <CheckBox x:Name="DarkThemeCheck" IsChecked="True" VerticalAlignment="Center"
                      Foreground="White" Click="DarkTheme_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Data stored at:" Foreground="#888" FontFamily="Segoe UI" FontSize="12" Margin="0,0,0,4"/>
            <TextBlock x:Name="StorePath" Text="" Foreground="#5B8AF5"
                       FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <Button Grid.Row="8" Content="Close" Width="80" Height="32" HorizontalAlignment="Right"
                Background="#5B8AF5" Foreground="White" BorderThickness="0" Cursor="Hand"
                Click="Close_Click"/>
    </Grid>
</Window>
