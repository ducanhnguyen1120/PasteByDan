<Window x:Class="PasteByDan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PasteByDan.Converters"
        xmlns:models="clr-namespace:PasteByDan.Models"
        Title="Paste by Dan"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <conv:TypeToColorConverter x:Key="TypeToColor"/>
        <conv:TypeToLabelConverter x:Key="TypeToLabel"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:Base64ToImageConverter x:Key="Base64ToImage"/>
        <conv:PinIconConverter x:Key="PinIcon"/>

        <Style x:Key="CardBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#5B8AF5"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgBrush}" CornerRadius="12,12,0,0"
            BorderBrush="#333333" BorderThickness="1,1,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBg}"
                    CornerRadius="12,12,0,0" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="TabAll" Content="All" Style="{StaticResource TabBtn}"
                                      IsChecked="True" Click="Tab_Click" Tag="All"/>
                        <ToggleButton x:Name="TabPinned" Content="📌 Pinned" Style="{StaticResource TabBtn}"
                                      Margin="4,0,0,0" Click="Tab_Click" Tag="Pinned"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ThemeBtn" Content="🌙" Style="{StaticResource CardBtn}"
                                FontSize="16" Padding="8,4" Click="Theme_Click" ToolTip="Toggle theme"/>
                        <Button Content="🗑" Style="{StaticResource CardBtn}"
                                FontSize="14" Padding="8,4" Margin="2,0" Click="ClearAll_Click"
                                ToolTip="Clear all unpinned items"/>
                        <Button Content="⚙" Style="{StaticResource CardBtn}"
                                FontSize="14" Padding="8,4" Margin="2,0" Click="Settings_Click"
                                ToolTip="Settings"/>
                        <Button Content="✕" Style="{StaticResource CardBtn}"
                                FontSize="14" Padding="8,4" Margin="4,0,0,0"
                                Click="CloseBtn_Click" ToolTip="Hide"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search bar -->
            <Border Grid.Row="1" Background="{DynamicResource TitleBarBg}" Padding="12,0,12,10">
                <Border Background="{DynamicResource SearchBg}" CornerRadius="8" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                                   Foreground="#555" Margin="0,0,6,0" FontSize="13"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 Background="Transparent"
                                 Foreground="{DynamicResource SearchFg}"
                                 BorderThickness="0" FontFamily="Segoe UI" FontSize="13"
                                 Padding="0,8" CaretBrush="#5B8AF5"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Search clipboard history..." Foreground="#666"
                                                       FontFamily="Segoe UI" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource CueBannerBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>
            </Border>

            <!-- Cards -->
            <Border Grid.Row="2" Background="{DynamicResource CardsAreaBg}">
                <ScrollViewer x:Name="CardsScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="CardsList" ItemsSource="{Binding FilteredItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Margin="10,8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder"
                                        Width="170" Margin="0,0,8,0"
                                        Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="8"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseLeftButtonDown="Card_MouseLeftButtonDown">
                                    <Border.ContextMenu>
                                        <ContextMenu Tag="{Binding}">
                                            <MenuItem Header="Copy" Click="CtxCopy_Click" Tag="{Binding}"/>
                                            <MenuItem Header="Paste" Click="CtxPaste_Click" Tag="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="Pin / Unpin" Click="CtxPin_Click" Tag="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="Delete" Click="CtxDelete_Click" Tag="{Binding}" Foreground="#FF5555"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="8,8,8,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="4" Padding="5,2"
                                                    Background="{Binding Type, Converter={StaticResource TypeToColor}}">
                                                <TextBlock Text="{Binding Type, Converter={StaticResource TypeToLabel}}"
                                                           Foreground="White" FontSize="9" FontWeight="Bold"
                                                           FontFamily="Segoe UI"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" FontSize="11"
                                                       Text="{Binding IsPinned, Converter={StaticResource PinIcon}}"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="8,2">
                                            <TextBlock Text="{Binding Preview}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontFamily="Segoe UI" FontSize="12"
                                                       TextWrapping="Wrap" MaxHeight="60"
                                                       TextTrimming="CharacterEllipsis"
                                                       x:Name="PreviewText"/>
                                            <Image Source="{Binding ImageBase64, Converter={StaticResource Base64ToImage}}"
                                                   MaxHeight="70" Stretch="Uniform"
                                                   x:Name="PreviewImage" Visibility="Collapsed"/>
                                        </Grid>

                                        <Grid Grid.Row="2" Margin="8,4,8,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding TimeAgo}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        x:Name="HoverActions" Visibility="Collapsed">
                                                <Button Style="{StaticResource CardBtn}" Content="📌"
                                                        FontSize="11" Padding="4,2"
                                                        Click="CardPin_Click" Tag="{Binding}"/>
                                                <Button Style="{StaticResource CardBtn}" Content="🗑"
                                                        FontSize="11" Padding="4,2"
                                                        Click="CardDelete_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource CardHover}"/>
                                                    <Setter Property="BorderBrush" Value="#5B8AF5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ClipType.Image}">
                                        <Setter TargetName="PreviewText" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="PreviewImage" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="HoverActions" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
